{
  "name": "VEXTRO-Dev-Env",
  "build": {
    "dockerfile": "Dockerfile"
  },
  "customizations": {
    "vscode": {
      "extensions": [
        "dbaeumer.vscode-eslint",
        "esbenp.prettier-vscode",
        "christian-kohler.npm-intellisense"
      ]
    }
  },
  "forwardPorts": [5050, 5173, 8081],
  "portsAttributes": {
    "5050": { "label": "Backend API", "hostIP": "0.0.0.0", "elevateIfNeeded": true },
    "5173": { "label": "WebApp", "hostIP": "0.0.0.0", "elevateIfNeeded": true },
    "8081": { "label": "Expo Metro", "hostIP": "0.0.0.0", "elevateIfNeeded": true }
  },
  "remoteUser": "node",
  "workspaceFolder": "/workspaces/VEXTRO",
  "features": {
    "ghcr.io/devcontainers/features/common-utils:2": {
      "configureZshAsDefaultShell": true
    }
  }
}