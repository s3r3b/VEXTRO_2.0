{
  "name": "VEXTRO-Dev-Env",
  "build": {
    "dockerfile": "Dockerfile"
  },
  "customizations": {
    "vscode": {
      "extensions": [
        "dbaeumer.vscode-eslint",
        "esbenp.prettier-vscode",
        "christian-kohler.npm-intellisense"
      ]
    }
  },
  "forwardPorts": [
    5173,
    5050,
    8081
  ],
  "portsAttributes": {
    "5173": {
      "label": "WebApp (Vite)",
      "onAutoForward": "notify"
    },
    "5050": {
      "label": "VEXTRO Hub (Backend)",
      "onAutoForward": "notify",
      "visibility": "public"
    },
    "8081": {
      "label": "Metro Bundler (Mobile)",
      "onAutoForward": "notify"
    }
  },
  "remoteUser": "node",
  "workspaceFolder": "/workspaces/VEXTRO",
  "features": {
    "ghcr.io/devcontainers/features/common-utils:2": {
      "configureZshAsDefaultShell": true
    }
  }
}